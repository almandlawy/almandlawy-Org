{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "pgruae.com" }],
      "destination": "https://www.pgruae.com/:path*",
      "permanent": true
    },
    { "source": "/sam-palm-silver-iraq", "destination": "/silver-bars-iraq", "permanent": true },
    { "source": "/silver-bars-erbil", "destination": "/silver-bars-iraq", "permanent": true },
    { "source": "/allocated-storage-dubai", "destination": "/allocated-storage", "permanent": true },
    { "source": "/sell-gold-dubai", "destination": "/sell-back", "permanent": true },
    { "source": "/buy-silver-bars-dubai", "destination": "/silver-bars", "permanent": true },
    { "source": "/buy-gold-bars-dubai", "destination": "/gold-bars", "permanent": true },
    { "source": "/bullion-desk-iraq", "destination": "/iraq-bullion-quote", "permanent": true },
    { "source": "/contact", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "/images/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/videos/:path*",
      "destination": "/videos/:path*"
    },
    {
      "source": "/brand/:path*",
      "destination": "/brand/:path*"
    },
    {
      "source": "/((?!api/|images/|assets/|videos/|brand/|static-seo/|robots\\.txt|sitemap\\.xml|manifest\\.json|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/((?!api/|assets/|images/|videos/|brand/|static-seo/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/images/(.*)\\.webp",
      "headers": [
        { "key": "Content-Type", "value": "image/webp" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/brand/(.*)\\.(png|webp|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/videos/(.*)\\.(mp4|webm)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
